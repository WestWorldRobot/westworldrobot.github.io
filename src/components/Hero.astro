---
// Hero.astro - Displays the main hero section with title, venue badge and resource links
---
<section id="hero" class="content-section hero-section">
  <div class="title-wrapper">
    <h1 class="main-title">WestWorld: A Knowledge-Encoded Scalable</h1>
  </div>
  <p class="subtitle">Trajectory World Model for Diverse Robotic Systems</p>

  <!-- Venue badge -->
  <div class="venue-badge">
    <img src="/ICML-logo.svg" alt="ICML 2026" class="venue-logo" />
    <span class="venue-text">ICML 2026 <span class="venue-spotlight">Spotlight</span></span>
  </div>

  <!-- Resource links -->
  <div class="resources-section">
    <div class="resources-buttons">
      <a href="https://arxiv.org/abs/2603.14392" target="_blank" rel="noopener noreferrer" class="resource-button">
        <svg class="resource-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <line x1="16" y1="13" x2="8" y2="13"></line>
          <line x1="16" y1="17" x2="8" y2="17"></line>
          <polyline points="10 9 9 9 8 9"></polyline>
        </svg>
        <span>Paper</span>
      </a>

      <a href="https://github.com/511205787/WestWorld" target="_blank" rel="noopener noreferrer" class="resource-button">
        <svg class="resource-icon gh-icon" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.55 7.55 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
        </svg>
        <span>Code</span>
      </a>

      <a href="https://huggingface.co/datasets/ywang077/Trajectory_world_model_dataset" target="_blank" rel="noopener noreferrer" class="resource-button">
        <svg class="resource-icon" viewBox="0 0 24 24" aria-hidden="true">
          <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
          <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
          <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
        </svg>
        <span>Dataset</span>
      </a>
    </div>
  </div>
</section>

<style>
  .venue-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin: 1.25rem 0 0.25rem;
  }

  .venue-logo {
    height: 22px;
    width: auto;
    flex-shrink: 0;
  }

  .venue-text {
    font-size: 1.4rem;
    font-weight: 600;
    color: #2a2f6c;
    line-height: 1.2;
  }

  .venue-spotlight {
    font-weight: 800;
  }

  /* GitHub mark is a filled glyph, unlike the stroke-based feather icons */
  .gh-icon {
    fill: currentColor;
    stroke: none;
  }

  @media (max-width: 768px) {
    .venue-badge {
      flex-direction: column;
      gap: 0.4rem;
    }
    .venue-text {
      font-size: 1.15rem;
    }
  }
</style>
