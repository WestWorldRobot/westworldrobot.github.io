---
// Header.astro - Sticky top navigation bar (logo + section links + GitHub)
---
<header>
  <div class="container">
    <a href="#hero" class="info-badge">
      <svg class="badge-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="4" y="8" width="16" height="11" rx="2.5"></rect>
        <line x1="12" y1="8" x2="12" y2="4.6"></line>
        <circle cx="12" cy="3.4" r="1.2"></circle>
        <line x1="2.6" y1="12" x2="2.6" y2="15"></line>
        <line x1="21.4" y1="12" x2="21.4" y2="15"></line>
        <circle cx="9" cy="13" r="1.3"></circle>
        <circle cx="15" cy="13" r="1.3"></circle>
        <line x1="9.5" y1="16.5" x2="14.5" y2="16.5"></line>
      </svg>
      <span class="badge-text"><strong>WestWorld</strong></span>
    </a>

    <div class="nav-wrapper">
      <nav class="main-nav">
        <ul>
          <li><a href="#tldr">TL;DR</a></li>
          <li><a href="#methodology">Methodology</a></li>
          <li><a href="#experiments">Experiments</a></li>
          <li><a href="#authors-citation">Citation</a></li>
          <li>
            <a href="https://github.com/511205787/WestWorld" target="_blank" rel="noopener noreferrer" class="github-repo" aria-label="GitHub repository">
              <span class="repo-icon">
                <svg viewBox="0 0 16 16" width="22" height="22" aria-hidden="true" fill="currentColor">
                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.55 7.55 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
                </svg>
              </span>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<style>
  header {
    background-color: #fff;
    border-bottom: 1px solid #e0e0e0;
    height: var(--header-height, 60px);
    display: flex;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .container {
    max-width: var(--page-max-width, 1100px);
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    justify-content: space-between; /* Logo left, nav-wrapper right */
    align-items: center;
    width: 100%;
  }

  .nav-wrapper {
    display: flex;
    align-items: center;
    width: auto;
  }

  .main-nav {
    width: 100%;
  }

  .main-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    justify-content: flex-end;
    gap: 0.4rem;
    width: 100%;
  }

  .main-nav li {
    display: inline-block;
    white-space: nowrap;
  }

  .main-nav a {
    text-decoration: none;
    color: #555;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    padding: 0.5rem;
  }

  .main-nav a:hover,
  .main-nav a:focus {
    color: #2a2f6c;
  }

  /* GitHub repo icon */
  .github-repo {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: #333;
    padding: 4px;
    border-radius: 6px;
    transition: background-color 0.2s ease;
  }

  .github-repo:hover {
    background-color: rgba(0, 0, 0, 0.05);
  }

  .repo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #333;
  }

  /* Logo pill */
  .info-badge {
    display: inline-flex;
    align-items: center;
    padding: 8px 15px;
    background-color: #ffffff;
    border: 1px solid #ced4da;
    border-radius: 20px;
    gap: 8px;
    text-decoration: none;
    color: #212529;
    font-size: 1rem;
    transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease;
    min-width: 0;
    overflow: hidden;
  }

  .info-badge:hover {
    background-color: #e9ecef;
    border-color: #e9ecef;
    cursor: pointer;
  }

  .badge-icon-svg {
    height: 24px;
    width: 24px;
    flex-shrink: 0;
    color: #2a2f6c;
  }

  .badge-text {
    line-height: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #212529;
  }

  /* Mobile responsiveness */
  @media (max-width: 768px) {
    .container {
      padding: 0 0.5rem;
    }

    .main-nav ul {
      gap: 0;
      justify-content: flex-end;
    }

    .main-nav a {
      font-size: 0.8rem;
      padding: 0.25rem 0.35rem;
    }

    .info-badge {
      padding: 6px 10px;
      font-size: 0.9rem;
      max-width: 150px;
    }

    .badge-icon-svg {
      height: 20px;
      width: 20px;
    }

    .github-repo {
      padding: 2px;
    }

    .repo-icon svg {
      height: 20px;
      width: 20px;
    }
  }

  /* Very small screens */
  @media (max-width: 480px) {
    .info-badge {
      padding: 4px 6px;
      max-width: 44px;
      justify-content: center;
    }

    .badge-text {
      display: none;
    }

    .main-nav a {
      font-size: 0.75rem;
      padding: 0.2rem;
    }
  }
</style>
